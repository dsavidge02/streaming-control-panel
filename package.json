{
	"name": "streaming-control-panel",
	"private": true,
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"main": "apps/panel/server/dist/main/index.js",
	"scripts": {
		"start": "pnpm rebuild:electron && electron-vite dev",
		"dev": "pnpm rebuild:electron && electron-vite dev",
		"postinstall": "node scripts/patch-local-asar-cli.mjs",
		"rebuild:electron": "electron-rebuild -f -w better-sqlite3 --module-dir apps/panel/server",
		"rebuild:node": "pnpm --filter @panel/server rebuild better-sqlite3 && node scripts/touch-better-sqlite3-binding.mjs",
		"format:check": "biome format .",
		"format:fix": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm rebuild:node && pnpm -r test",
		"test:e2e": "pnpm --filter @panel/client test:e2e",
		"guard:no-test-changes": "node scripts/guard-no-test-changes.mjs",
		"red-verify": "pnpm format:check && pnpm lint && pnpm typecheck",
		"verify": "pnpm red-verify && pnpm test",
		"green-verify": "pnpm verify && pnpm guard:no-test-changes",
		"verify-all": "pnpm verify && pnpm test:e2e",
		"smoke:packaged": "node scripts/smoke-packaged.mjs",
		"verify-full": "pnpm verify-all && pnpm package && pnpm smoke:packaged",
		"package": "node scripts/package-and-restore-native.mjs"
	},
	"dependencies": {
		"@fastify/cookie": "^11",
		"@fastify/merge-json-schemas": "^0.2.0",
		"ajv": "^8.12.0",
		"ajv-formats": "^3.0.1",
		"better-sqlite3": "^12.9.0",
		"dequal": "^2.0.3",
		"drizzle-orm": "^0.45.2",
		"fast-json-stringify": "^6.3.0",
		"fast-uri": "^3.0.0",
		"fastify": "^5.8.5",
		"fastify-type-provider-zod": "^6.1.0",
		"iron-session": "^8",
		"json-schema-ref-resolver": "^3.0.0",
		"rfdc": "^1.2.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2",
		"@tailwindcss/vite": "^4.1",
		"@vitejs/plugin-react": "^5",
		"@electron/rebuild": "^4.0.3",
		"electron": "^41.2.1",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5",
		"typescript": "^5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"electron",
			"electron-winstaller"
		]
	}
}
